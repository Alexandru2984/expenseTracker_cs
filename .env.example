# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values
# Never commit the real .env file (it's in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string for the API
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=expense_tracker;Username=expense_user;Password=CHANGE_ME

# JWT signing secret — min 32 characters, used to sign/verify authentication tokens
# Generate with: openssl rand -hex 32
Jwt__Secret=CHANGE_ME_USE_OPENSSL_RAND_HEX_32

# Comma-separated list of allowed CORS origins (leave empty in production
# when frontend is served same-origin through Nginx)
Cors__AllowedOrigins=

# Host header allow-list (defense against host-header attacks). In production set
# this to your real domain(s), comma-separated. Use * only for local dev.
AllowedHosts=your-domain.example.com

# CIDR ranges of trusted reverse proxies (Nginx/Docker bridge). Forwarded
# headers (X-Forwarded-For/Proto) are only honored from these. Leave unset to
# use the safe defaults (loopback + RFC1918 private ranges).
# ForwardedHeaders__TrustedNetworks=172.16.0.0/12,127.0.0.0/8

# ASP.NET Core environment: Production | Development
ASPNETCORE_ENVIRONMENT=Production

# PostgreSQL container credentials (used by the db service in docker-compose.yml)
POSTGRES_DB=expense_tracker
POSTGRES_USER=expense_user
POSTGRES_PASSWORD=CHANGE_ME
