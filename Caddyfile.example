# ─────────────────────────────────────────────────────────────────────────────
# Caddyfile.example
# Copy to `Caddyfile` and replace `your-domain.com` with your actual domain.
# Caddy will obtain a TLS certificate from Let's Encrypt automatically.
# ─────────────────────────────────────────────────────────────────────────────

your-domain.com {
    # Reverse proxy API requests to the backend container
    reverse_proxy /api/* api:8080

    # Serve the Vue frontend static files
    root * /srv
    file_server

    # SPA fallback — send all non-file requests to index.html
    try_files {path} /index.html

    encode gzip
}
